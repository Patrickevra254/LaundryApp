    protected $paystack;

    public function __construct()
    {
        $this->paystack = new Paystack(env('PAYSTACK_SECRET_KEY'));
    }

    /**
     * Redirect customer to Paystack to pay
     */
    public function redirectToGateway(Request $request)
    {
        $validated = $request->validate([
            'customer_id' => 'required|exists:users,id',
            'pickup_address' => 'required|string',
            'delivery_address' => 'required|string',
            'pickup_date' => 'required|date',
            'delivery_date' => 'required|date|after_or_equal:pickup_date',
            'items' => 'required|array|min:1',
            'email' => 'required|email',
            'amount' => 'required|numeric|min:1',
        ]);

        // Save order data in session
        session(['order_data' => $request->all()]);

        // Generate unique reference
        $reference = uniqid('laundry_');

        try {
            $tranx = $this->paystack->transaction->initialize([
                'amount' => $request->amount * 100, // convert to kobo
                'email' => $request->email,
                'reference' => $reference,
            ]);

            return redirect($tranx->data->authorization_url);

        } catch (\Exception $e) {
            return back()->with('error', 'Payment initialization failed: ' . $e->getMessage());
        }
    }

    /**
     * Handle Paystack callback after payment
     */
    public function handleGatewayCallback(Request $request)
    {
        try {
            $tranx = $this->paystack->transaction->verify([
                'reference' => $request->query('reference')
            ]);

            if ($tranx->data->status !== 'success') {
                return redirect()->route('bookLaundry')->with('error', 'Payment failed or cancelled.');
            }

            $orderData = session('order_data');
            if (!$orderData) {
                return redirect()->route('bookLaundry')->with('error', 'No order data found.');
            }

            $reference = $tranx->data->reference;

            if (Payment::where('reference', $reference)->exists()) {
                return redirect()->route('bookLaundry')->with('error', 'Payment already processed.');
            }

            // Create order + items + payment inside transaction
            $order = DB::transaction(function () use ($orderData, $tranx, $reference) {

                $serviceFee = 200;
                $subtotal = 0;
                $totalItems = 0;

                // Create LaundryOrder
                $order = LaundryOrder::create([
                    'customer_id' => $orderData['customer_id'],
                    'pickup_address' => $orderData['pickup_address'],
                    'delivery_address' => $orderData['delivery_address'],
                    'pickup_date' => $orderData['pickup_date'],
                    'delivery_date' => $orderData['delivery_date'],
                    'total_items' => 0,
                    'subtotal' => 0,
                    'service_fee' => $serviceFee,
                    'total_amount' => 0,
                    'payment_status' => 'paid',
                    'created_by' => auth()->id(),
                ]);

                // Create LaundryOrderItems
                foreach ($orderData['items'] as $row) {
                    $item = LaundryItem::findOrFail($row['item_id']); // make sure item exists
                    $qty = $row['quantity'] ?? 1;

                    $price = match ($row['service_type']) {
                        'washing' => $item->washing_price,
                        'ironing' => $item->ironing_price,
                        'wash_and_iron' => $item->wash_and_iron_price,
                    };

                    $subtotal += $price * $qty;
                    $totalItems += $qty;

                    LaundryOrderItem::create([
                        'laundry_order_id' => $order->id,
                        'laundry_item_id' => $item->id,
                        'item_name' => $item->name, // no more null
                        'service_type' => $row['service_type'],
                        'price' => $price,
                        'quantity' => $qty,
                        'subtotal' => $price * $qty,
                    ]);
                }

                // Update totals
                $order->update([
                    'total_items' => $totalItems,
                    'subtotal' => $subtotal,
                    'total_amount' => $subtotal + $serviceFee,
                ]);

                // Record Payment
                Payment::create([
                    'laundry_order_id' => $order->id,
                    'amount' => $order->total_amount,
                    'reference' => $reference,
                    'status' => 'success',
                    'currency' => 'NGN',
                ]);

                return $order;
            });

            session()->forget('order_data');

            return redirect()->route('bookLaundry')->with('success', 'Payment successful and order created!');

        } catch (\Exception $e) {
            return redirect()->route('bookLaundry')->with('error', 'Payment verification failed: ' . $e->getMessage());
        }
    }
}


