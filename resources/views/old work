<script>
    document.addEventListener("DOMContentLoaded", function() {

        const tableBody = document.querySelector(".table tbody");
        const addBtn = document.querySelector(".card-header .btn-outline-primary");
        const totalItemsEl = document.querySelector(
            ".position-sticky .card-body div:nth-child(1) span:last-child");
        const subtotalEl = document.querySelector(
            ".position-sticky .card-body div:nth-child(2) span:last-child");
        const totalEl = document.querySelector(".position-sticky .card-body .fw-bold span");

        function updateTotals() {
            let totalItems = 0;
            let subtotal = 0;

            tableBody.querySelectorAll("tr").forEach(row => {
                const qtyInput = row.querySelector('input[type="number"]');
                const priceInput = row.querySelector('input[disabled]');
                const subtotalCell = row.querySelector('td.fw-semibold');

                const qty = parseInt(qtyInput.value) || 0;
                const price = parseInt(priceInput.value.replace(/[^\d]/g, '')) || 0;

                const rowSubtotal = qty * price;
                subtotalCell.textContent = '₦' + rowSubtotal.toLocaleString();

                totalItems += qty;
                subtotal += rowSubtotal;
            });

            const serviceFee = 200;
            const total = subtotal + serviceFee;

            totalItemsEl.textContent = totalItems;
            subtotalEl.textContent = '₦' + subtotal.toLocaleString();
            totalEl.textContent = '₦' + total.toLocaleString();
        }

        // Initial update
        updateTotals();

        // Quantity change
        tableBody.addEventListener('input', function(e) {
            if (e.target.type === 'number') updateTotals();
        });

        // Delete row
        tableBody.addEventListener('click', function(e) {
            if (e.target.closest(".btn-outline-danger")) {
                e.target.closest("tr").remove();
                updateTotals();
            }
        });

        // Add new item
        addBtn.addEventListener("click", function() {
            const newRow = document.createElement("tr");
            newRow.innerHTML = `
            <td data-label="Item">
                <select class="form-select">
                    <option>Singlet</option>
                    <option>Boxer</option>
                    <option>Jeans</option>
                    <option>Polo T-Shirt</option>
                    <option>Gown</option>
                    <option>Skirt</option>
                    <option>Thick Bedsheet</option>
                    <option>Light Bedsheet</option>
                    <option>Jacket</option>
                    <option>Towel</option>
                </select>
            </td>
            <td data-label="Price">
                <input type="text" class="form-control" value="₦500" disabled>
            </td>
            <td data-label="Qty">
                <input type="number" class="form-control" value="1" min="1">
            </td>
            <td data-label="Subtotal" class="fw-semibold">₦500</td>
            <td data-label="Action" class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger">
                    <i class="fa fa-trash"></i>
                </button>
            </td>
        `;
            tableBody.appendChild(newRow);
            updateTotals();
        });

    });
</script>
